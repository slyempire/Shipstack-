{
  "entities": {
    "User": {
      "title": "User",
      "description": "System user with role-based access control",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "role": { "type": "string", "enum": ["ADMIN", "DISPATCHER", "FINANCE", "FACILITY", "DRIVER", "CLIENT", "WAREHOUSE"] },
        "company": { "type": "string" },
        "verificationStatus": { "type": "string", "enum": ["PENDING", "VERIFIED", "REJECTED"] },
        "enabledModules": { "type": "array", "items": { "type": "string" } }
      },
      "required": ["id", "name", "email", "role"]
    },
    "PermissionRequest": {
      "title": "Permission Request",
      "description": "User request for module access",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "userName": { "type": "string" },
        "userEmail": { "type": "string" },
        "moduleId": { "type": "string" },
        "status": { "type": "string", "enum": ["PENDING", "APPROVED", "REJECTED"] },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" },
        "adminNotes": { "type": "string" },
        "userNotes": { "type": "string" }
      },
      "required": ["id", "userId", "userName", "userEmail", "moduleId", "status", "createdAt"]
    },
    "DeliveryNote": {
      "title": "Delivery Note",
      "description": "Core logistics document for tracking shipments",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "tenantId": { "type": "string" },
        "externalId": { "type": "string" },
        "clientName": { "type": "string" },
        "status": { "type": "string" },
        "priority": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "driverId": { "type": "string" },
        "vehicleId": { "type": "string" },
        "mpesaTillNumber": { "type": "string" },
        "tempRequirement": { "type": "object" }
      },
      "required": ["id", "tenantId", "externalId", "clientName", "status", "priority", "createdAt"]
    },
    "Vehicle": {
      "title": "Vehicle",
      "description": "Fleet asset",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "tenantId": { "type": "string" },
        "plate": { "type": "string" },
        "type": { "type": "string" },
        "capacityKg": { "type": "number" },
        "status": { "type": "string" },
        "lastLat": { "type": "number" },
        "lastLng": { "type": "number" },
        "lastTelemetryAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "tenantId", "plate", "type", "status"]
    },
    "Trip": {
      "title": "Trip",
      "description": "Driver trip assignment",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "tenantId": { "type": "string" },
        "driverId": { "type": "string" },
        "vehicleId": { "type": "string" },
        "status": { "type": "string" },
        "dnIds": { "type": "array", "items": { "type": "string" } },
        "startTime": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "tenantId", "driverId", "vehicleId", "status", "dnIds"]
    },
    "TelemetryPing": {
      "title": "Telemetry Ping",
      "description": "High-frequency GPS data point",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "tenantId": { "type": "string" },
        "tripId": { "type": "string" },
        "vehicleId": { "type": "string" },
        "lat": { "type": "number" },
        "lng": { "type": "number" },
        "speed": { "type": "number" },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "tenantId", "lat", "lng", "timestamp"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profiles and settings"
    },
    "/permission_requests/{requestId}": {
      "schema": "PermissionRequest",
      "description": "User requests for module access"
    },
    "/delivery_notes/{dnId}": {
      "schema": "DeliveryNote",
      "description": "Logistics delivery notes"
    },
    "/vehicles/{vehicleId}": {
      "schema": "Vehicle",
      "description": "Fleet assets"
    },
    "/trips/{tripId}": {
      "schema": "Trip",
      "description": "Driver trip assignments"
    },
    "/telemetry_pings/{pingId}": {
      "schema": "TelemetryPing",
      "description": "Historical GPS tracking data"
    },
    "/facilities/{facilityId}": {
      "schema": "object",
      "description": "Warehouses and distribution centers"
    },
    "/inventory/{itemId}": {
      "schema": "object",
      "description": "Warehouse stock items"
    },
    "/audit_logs/{logId}": {
      "schema": "object",
      "description": "System audit trail"
    }
  }
}
